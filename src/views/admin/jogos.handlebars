<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🎮 Gerenciar Jogos</h2>

    <div>
      <a href="/admin/dashboard" class="btn btn-secondary">
        🏠 Painel
      </a>

      <a href="/admin/jogos/novo" class="btn btn-primary">
        ➕ Criar Novo Jogo
      </a>
    </div>
  </div>

  {{#if jogos.length}}

  <div class="table-responsive">

    <table class="table table-hover align-middle shadow-sm">

      <thead class="table-dark">
        <tr>
          <th style="width:80px">ID</th>
          <th style="width:160px">PIN do Jogo</th>
          <th style="width:140px">Status</th>
          <th style="width:160px">Data de Criação</th>
          <th style="width:380px" class="text-center">Ações</th>
        </tr>
      </thead>

      <tbody>

        {{#each jogos}}
        <tr>

          <td class="text-muted fw-bold">
            #{{id}}
          </td>

          <td>
            <span class="badge bg-primary fs-5 px-3 py-2">
              {{pin}}
            </span>
          </td>

          <td>

            {{#if (eq status "ativo")}}
            <span class="badge bg-success">
              🟢 Ativo
            </span>
            {{else}}
            <span class="badge bg-secondary">
              ⚪ Finalizado
            </span>
            {{/if}}

          </td>

          <td>
            {{{formatDateTooltip data_criacao}}}
          </td>

          <td class="text-center">

            <a href="/admin/jogos/questoes/{{id}}" class="btn btn-sm btn-info">
              📝 Questões
            </a>

            <a href="/admin/jogos/exibir/{{id}}" class="btn btn-sm btn-success">
              🎮 Abrir Jogo
            </a>

            <a href="/admin/jogos/excluir/{{id}}" 
               class="btn btn-sm btn-danger"
               onclick="return confirm('Tem certeza que deseja excluir este jogo?');">
              🗑️ Excluir Jogo
            </a>

          </td>

        </tr>
        {{/each}}

      </tbody>

    </table>

  </div>

  {{else}}

  <div class="alert alert-info text-center p-4">

    🎮 Nenhum jogo criado ainda.

    <br><br>

    <a href="/admin/jogos/novo" class="btn btn-primary">
      ➕ Criar primeiro jogo
    </a>

  </div>

  {{/if}}

</div>