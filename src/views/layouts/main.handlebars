<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <title>Velha da Figura de Linguagem</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;

      background: linear-gradient(135deg, #6a11cb, #2575fc);
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: white;
    }

    .game-card {
      background: white;
      color: #333;
      padding: 40px;
      border-radius: 15px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
      max-width: 400px;
      width: 100%;
    }

    .game-title {
      font-weight: 700;
      text-align: center;
      margin-bottom: 10px;
    }

    .game-subtitle {
      text-align: center;
      font-size: 14px;
      color: #666;
      margin-bottom: 25px;
    }

    .btn-game {
      font-size: 18px;
      font-weight: 600;
      padding: 12px;
      border-radius: 10px;
    }

    input {
      border-radius: 10px !important;
      padding: 12px !important;
    }

    /* ===== Estilos do Jogo ===== */
    /* Container principal */
    .container-jogo {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
      padding: 20px;
    }

    /* Cabeçalho */
    .header-jogo {
      text-align: center;
    }

    .tabuleiro {
      display: grid;
      grid-template-columns: repeat(3, 100px);
      gap: 5px;
      margin-top: 20px;
    }

    .casa {
      width: 100px;
      height: 100px;
      font-size: 32px;
      cursor: pointer;
    }

    .modal-questao {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.5);
      justify-content: center;
      align-items: center;
    }

    .modal-conteudo {
      background: white;
      padding: 20px;
      border-radius: 8px;
      max-width: 400px;
      width: 90%;
    }

    .enunciado-questao{
      color: #333 !important;
    }

    .btn-alternativa {
      display: block;
      width: 100%;
      margin: 5px 0;
      padding: 8px;
      font-size: 16px;
      cursor: pointer;
    }

    .feedback-questao {
      margin-top: 10px;
      font-weight: bold;
      font-size: 16px;
    }

    .botoes-jogo {
      margin-top: 20px;
      display: flex;
      gap: 10px;
    }

    /* ===== Responsividade ===== */
    @media (max-width: 500px) {
      .tabuleiro {
        grid-template-columns: repeat(3, 70px);
        gap: 8px;
      }

      .casa {
        width: 70px;
        height: 70px;
        font-size: 28px;
      }

      .alternativas-container button {
        font-size: 16px;
        padding: 6px;
      }

      .btn-fechar {
        font-size: 14px;
        padding: 6px;
      }
    }

    /* ===== Feedback das alternativas ===== */

    .btn-alternativa {
      border: 1px solid #ccc;
      background-color: #f8f9fa;
      color: #333;
      border-radius: 6px;
      transition: all 0.3s ease;
    }

    /* Resposta correta (verde) */
    .btn-alternativa.correta {
      background-color: #28a745;
      color: #fff;
      border-color: #28a745;
    }

    /* Resposta errada (vermelho) */
    .btn-alternativa.errada {
      background-color: #dc3545;
      color: #fff;
      border-color: #dc3545;
    }

    /* Botões desabilitados */
    .btn-alternativa:disabled {
      cursor: not-allowed;
      opacity: 0.95;
    }

    /* Efeito hover (antes de responder) */
    .btn-alternativa:hover:not(:disabled) {
      background-color: #e2e6ea;
    }
  </style>

</head>

<body>

  {{{body}}}

</body>

</html>