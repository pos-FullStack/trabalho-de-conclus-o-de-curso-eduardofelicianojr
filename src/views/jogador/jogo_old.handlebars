<div class="container-jogo">

<div class="d-flex align-items-center mb-3">
      <div class="me-3">
        <img src="/img/velha.png" alt="Velha" class="img-fluid" style="max-width: 50px;">
      </div>
      <div>
        <h3 class="game-title m-0">Velha da Figura de Linguagem</h3>
      </div>
    </div>


  <!-- Cabeçalho do jogador -->
  <div class="header-jogo">
    
    <h3>Jogador: {{jogadorNome}} | PIN do Jogo: {{session.jogoPin}}</h3>
  </div>

  <!-- Tabuleiro -->
  <div id="tabuleiro" class="tabuleiro">
    {{#each tabuleiroArray}}
    <button class="casa" data-posicao="{{this}}"></button>
    {{/each}}
  </div>

  <!-- Botões -->
  <div class="botoes-jogo">
    <button id="novoJogo" class="btn btn-success">♻️ Novo Jogo</button>
    <button id="sairJogo" class="btn btn-danger">🚪 Sair</button>
  </div>

  <!-- Modal da questão -->
  <div id="modalQuestao" class="modal-questao">
    <div class="modal-conteudo">
      <h3 id="enunciado" class="enunciado-questao"></h3>
      <div id="alternativas" class="alternativas-container"></div>
      <p id="feedback" class="feedback-questao"></p>
      <button id="fecharModal" class="btn-fechar">Fechar</button>
    </div>
  </div>

</div>

<script>
  const casas = document.querySelectorAll('.casa');
  const modal = document.getElementById('modalQuestao');
  const enunciadoEl = document.getElementById('enunciado');
  const alternativasEl = document.getElementById('alternativas');
  const feedbackEl = document.getElementById('feedback');
  const fecharModalBtn = document.getElementById('fecharModal');
  const btnNovoJogo = document.getElementById('novoJogo');
  const btnSair = document.getElementById('sairJogo');

  let posicaoAtual = null;
  let tabuleiroEstado = Array(9).fill(null);

  // Símbolos e cores
  const simbolos = { correto: 'O', incorreto: 'X' };
  const cores = { correto: 'blue', incorreto: 'red' };

  // Sequências vencedoras
  const sequenciasVencedoras = [
    [0, 1, 2], [3, 4, 5], [6, 7, 8],
    [0, 3, 6], [1, 4, 7], [2, 5, 8],
    [0, 4, 8], [2, 4, 6]
  ];

  // Abrir modal com questão
  async function abrirQuestao(posicao) {
    posicaoAtual = posicao;

    const res = await fetch('/proxima-questao');
    const data = await res.json();

    enunciadoEl.textContent = data.enunciado;
    enunciadoEl.style.color = '#000';
    feedbackEl.textContent = '';
    alternativasEl.innerHTML = '';

    for (const letra in data.alternativas) {
      const btn = document.createElement('button');
      btn.textContent = `${letra}: ${data.alternativas[letra]}`;
      btn.classList.add('btn-alternativa');
      btn.addEventListener('click', () => enviarResposta(letra, data.feedback, data.correta));
      alternativasEl.appendChild(btn);
    }

    modal.style.display = 'flex';
  }

  // Enviar resposta
  async function enviarResposta(resposta, feedback, correta) {
    if (posicaoAtual === null) return;

    // Bloqueia alternativas
    alternativasEl.querySelectorAll('button').forEach(b => b.disabled = true);

    const casa = document.querySelector(`.casa[data-posicao='${posicaoAtual}']`);

    if (resposta === correta) {
      casa.textContent = simbolos.correto;
      casa.style.color = cores.correto;
      tabuleiroEstado[posicaoAtual] = simbolos.correto;
      feedbackEl.style.color = cores.correto;
    } else {
      casa.textContent = simbolos.incorreto;
      casa.style.color = cores.incorreto;
      tabuleiroEstado[posicaoAtual] = simbolos.incorreto;
      feedbackEl.style.color = cores.incorreto;
    }

    feedbackEl.textContent = feedback;

    // Fecha modal após 1,2s para que o usuário veja o feedback
    setTimeout(() => {
      modal.style.display = 'none';
      posicaoAtual = null;
      verificarVitoria();
    }, 12000);
  }

  // Verificar vitória/derrota/empate
  function verificarVitoria() {
    for (const seq of sequenciasVencedoras) {
      const [a, b, c] = seq;
      if (tabuleiroEstado[a] && tabuleiroEstado[a] === tabuleiroEstado[b] && tabuleiroEstado[a] === tabuleiroEstado[c]) {
        const vencedor = tabuleiroEstado[a] === simbolos.correto ? '🎉 Vitória!' : '💀 Derrota!';
        alert(vencedor);
        casas.forEach(c => c.disabled = true);
        return;
      }
    }

    if (tabuleiroEstado.every(c => c !== null)) {
      alert('🤝 Empate!');
      casas.forEach(c => c.disabled = true);
    }
  }

  // Fechar modal
  fecharModalBtn.addEventListener('click', () => {
    modal.style.display = 'none';
    posicaoAtual = null;
  });

  // Abrir modal ao clicar na casa
  casas.forEach(casa => {
    casa.addEventListener('click', () => {
      if (casa.textContent) return;
      abrirQuestao(parseInt(casa.dataset.posicao));
    });
  });

  // Novo jogo
  btnNovoJogo.addEventListener('click', () => {
    if (confirm('Deseja realmente reiniciar o jogo? Todo progresso será perdido.')) {
      tabuleiroEstado.fill(null);
      casas.forEach(c => { c.textContent = ''; c.style.color = ''; c.disabled = false; });
      alert('🔄 Novo jogo iniciado!');
    }
  });

  // Sair do jogo
  btnSair.addEventListener('click', () => {
    if (confirm('Deseja realmente sair do jogo?')) {
      window.location.href = '/entrar';
    }
  });
</script>